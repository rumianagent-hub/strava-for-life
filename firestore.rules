rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Goals ────────────────────────────────────────────────────────────────
    match /goals/{goalId} {
      // Owner can create goals
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid;

      // Owner can read, update, delete their own goals
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;

      // Squad members can read squad-visible goals
      allow read: if request.auth != null
        && resource.data.privacy == "squad"
        && resource.data.squadId != null
        && exists(/databases/$(database)/documents/squads/$(resource.data.squadId))
        && request.auth.uid in get(/databases/$(database)/documents/squads/$(resource.data.squadId)).data.memberUids;

      // ─── Checkins ─────────────────────────────────────────────────────────
      match /checkins/{date} {
        // Readable if parent goal is readable (simplified: owner or squad member)
        allow read: if request.auth != null
          && (
            request.auth.uid == get(/databases/$(database)/documents/goals/$(goalId)).data.ownerUid
            || (
              get(/databases/$(database)/documents/goals/$(goalId)).data.privacy == "squad"
              && get(/databases/$(database)/documents/goals/$(goalId)).data.squadId != null
              && request.auth.uid in get(/databases/$(database)/documents/squads/$(get(/databases/$(database)/documents/goals/$(goalId)).data.squadId)).data.memberUids
            )
          );

        // Only owner can write checkins
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/goals/$(goalId)).data.ownerUid;
      }
    }

    // ─── Squads ───────────────────────────────────────────────────────────────
    match /squads/{squadId} {
      // Members can read the squad
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      // Also allow reading by invite code lookup (unauthenticated preview)
      allow read: if true;

      // Owner can update
      allow update: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;

      // Any authenticated user can create a squad (they'll be the owner)
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid
        && request.auth.uid in request.resource.data.memberUids;

      // Members can join (update memberUids) if squad is not full
      allow update: if request.auth != null
        && request.auth.uid in request.resource.data.memberUids
        && !(request.auth.uid in resource.data.memberUids)
        && request.resource.data.memberUids.size() <= resource.data.maxMembers
        && request.resource.data.keys().hasOnly(resource.data.keys())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']);
    }
  }
}
